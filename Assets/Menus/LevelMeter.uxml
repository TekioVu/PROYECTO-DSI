    <ui:VisualElement name="level-meter__container" picking-mode="Ignore" class="cursor-a level-meter__container text__font--default" style="margin-top: 0%; margin-right: 0%; margin-bottom: 0%; margin-left: 0%;">
        <UIToolkitDemo.AspectRatioElement width="1" height="1" name="square__container" picking-mode="Ignore" style="width: 81%; height: 70%; position: relative; left: auto; top: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;">
            <ui:VisualElement name="level-meter__counter-group" class="xp-meter__counter-group cursor-a" style="background-color: rgba(44, 62, 80, 0); align-items: center; justify-content: center; top: -1%; left: 4%; -unity-background-scale-mode: scale-to-fit; position: relative; background-size: 100% 100%;">
                <ui:VisualElement name="level-meter__background" picking-mode="Ignore" class="cursor-a level-meter__background" style="background-size: 100% 100%;"/>
                <UIToolkitDemo.RadialProgress track-color="#2E2E2EFF" name="level-meter__radial-progress" progress="19" class="text__font--default" style="position: absolute; width: 86%; height: 81%;"/>
            </ui:VisualElement>
            <ui:VisualElement name="level-meter__avatar" picking-mode="Ignore" class="xp-meter__icon level-meter__avatar" style="top: 13%; left: 17%; height: 73%; width: 75%; background-size: 100% 100%;"/>
        </UIToolkitDemo.AspectRatioElement>
    </ui:VisualElement>
</ui:UXML>
