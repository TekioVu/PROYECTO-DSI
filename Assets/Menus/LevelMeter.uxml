<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/USS/LevelMeter.uss?fileID=7433441132597879392&amp;guid=7f211cd979cc89246b08e7820713313e&amp;type=3#LevelMeter"/>
